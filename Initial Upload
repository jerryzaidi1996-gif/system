  for (const shadow of SHADOWS) {
    if (!state.unlockedShadows.includes(shadow.id) && shadow.check(state)) {
      state.unlockedShadows.push(shadow.id);
      newShadows.push(shadow);
    }
  }

  for (const ach of ACHIEVEMENTS) {
    if (!state.unlockedAchievements.includes(ach.id) && ach.check(state)) {
      state.unlockedAchievements.push(ach.id);
      if (!state.earnedTitles.includes(ach.title)) {
        state.earnedTitles.push(ach.title);
      }
      newAchievements.push(ach);
    }
  }

  // Queue unlock cinematics
  if (newShadows.length > 0 || newAchievements.length > 0) {
    queueUnlockAnimations(newShadows, newAchievements);
  }
}

