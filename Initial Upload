  btn.textContent = mission.completed ? '✓ CONQUERED' : 'COMPLETE';
  if (!mission.completed) {
    btn.addEventListener('click', () => completeLongTermMission(scope));
  }
  actions.appendChild(btn);

  body.appendChild(actions);
  card.appendChild(body);
  return card;
}

function completeLongTermMission(scope) {
  let mission;
  if (scope === 'weekly') mission = state.weeklyMission;
  else if (scope === 'monthly') mission = state.monthlyArc;
  else if (scope === 'dungeon') mission = state.longTermDungeon;

  if (!mission || mission.completed) return;

  mission.completed = true;
  mission.completedAt = new Date().toISOString();

  const xpGained = XP_BY_DIFFICULTY[mission.d] || 200;
  state.totalXp += xpGained;

  // Award stats (boss multiplier gives big gains)
  const statGains = calculateStatGains(mission.category, mission.d);
  for (const [stat, amt] of Object.entries(statGains)) {
    state.stats[stat] = (state.stats[stat] || 0) + amt;
  }

  // Phase 4: count as quest completion
  state.totalQuestsCompleted = (state.totalQuestsCompleted || 0) + 1;
  if (!state.questsCompletedByCategory) state.questsCompletedByCategory = { scholar: 0, research: 0, iron: 0, dungeon: 0, recovery: 0 };
  state.questsCompletedByCategory[mission.category] = (state.questsCompletedByCategory[mission.category] || 0) + 1;

  // Update streak
  const streakResult = updateStreakOnCompletion();
  if (state.streak > (state.maxStreakEver || 0)) state.maxStreakEver = state.streak;

  // Check rank up
  const newRankIdx = calculateRank(state.totalXp);
  const didRankUp = newRankIdx > state.currentRankIdx;
  const prevRank = RANKS[state.currentRankIdx].name;
  if (didRankUp) state.currentRankIdx = newRankIdx;

  const labels = { weekly: 'WEEKLY MISSION', monthly: 'MONTHLY ARC', dungeon: 'LONG-TERM DUNGEON' };
  const statText = Object.entries(statGains).map(([s, a]) => `+${a} ${s}`).join(' · ');

  logMessage(`${labels[scope]} CONQUERED — ${mission.text.toUpperCase()} · +${xpGained} EXP${statText ? ' · ' + statText : ''}`, 'xp');

  // Phase 4: check for new unlocks
  checkAndUnlockProgress();

  saveState();
  render();

  showToast(`${labels[scope]} CONQUERED. +${xpGained} EXP${statText ? ' · ' + statText : ''}.`, 'accent');

  if (streakResult.milestone) {
    setTimeout(() => {
      showToast(`STREAK MILESTONE. ${streakResult.milestone} DAYS OF DISCIPLINE.`, 'accent');
      logMessage(`STREAK MILESTONE REACHED — ${streakResult.milestone} DAYS`, 'streak');
    }, 700);
  }

  if (didRankUp) {
    setTimeout(() => showRankUp(prevRank, RANKS[newRankIdx].name), 900);
    logMessage(`RANK ASCENSION — ${prevRank} → ${RANKS[newRankIdx].name}`, 'rank');
  }
}

function renderStats() {
  const prevStats = window._prevStats || {};
  for (const stat of ['INT', 'STR', 'VIT', 'AGI', 'SEN']) {
    const value = state.stats[stat] || 0;
    const valueEl = document.getElementById(`stat${stat}`);
    const barEl = document.getElementById(`statBar${stat}`);
    if (!valueEl || !barEl) continue;

    // Pulse animation if value increased
    if (prevStats[stat] !== undefined && value > prevStats[stat]) {
      valueEl.classList.remove('pulse');
      void valueEl.offsetWidth;
      valueEl.classList.add('pulse');
    }

    valueEl.textContent = value;

    // Progress bar: logarithmic fill so early gains feel rewarding but scale to very high values
    const pct = Math.min(100, (Math.log(value + 1) / Math.log(1001)) * 100);
    barEl.style.width = pct + '%';
  }
  window._prevStats = { ...state.stats };
}

function renderStreak() {
  const flame = document.getElementById('streakFlame');
  const count = document.getElementById('streakCount');
  const row = flame ? flame.closest('.streak-row') : null;
  if (!count) return;

  count.textContent = state.streak;
  count.classList.toggle('streak-count', true);

  if (state.streak > 0) {
    flame.classList.add('active');
    if (row) row.classList.add('active');
  } else {
    flame.classList.remove('active');
    if (row) row.classList.remove('active');
  }
}

function renderFeed() {
  const body = document.getElementById('feedBody');
  const count = document.getElementById('feedCount');
  if (!body) return;

  if (state.messageFeed.length === 0) {
    body.innerHTML = '<div class="feed-empty">『 No messages yet 』</div>';
    if (count) { count.textContent = '0'; count.setAttribute('data-count', '0'); }
    return;
  }

  body.innerHTML = '';
  for (const msg of state.messageFeed) {
    const entry = document.createElement('div');
    entry.className = 'feed-entry';
    entry.setAttribute('data-type', msg.type || 'info');

    const timeEl = document.createElement('span');
    timeEl.className = 'feed-entry-time';
    timeEl.textContent = formatFeedTime(msg.ts);

    const textEl = document.createElement('span');
    textEl.className = 'feed-entry-text';
    textEl.textContent = msg.text;

    entry.appendChild(timeEl);
    entry.appendChild(textEl);
    body.appendChild(entry);
  }

  if (count) {
    count.textContent = state.messageFeed.length;
    count.setAttribute('data-count', state.messageFeed.length);
  }
}

