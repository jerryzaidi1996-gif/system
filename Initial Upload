function queueUnlockAnimations(shadows, achievements) {
  for (const s of shadows) {
    unlockQueue.push({ type: 'shadow', data: s });
    logMessage(`NEW SHADOW ACQUIRED — ${s.name} · ${s.class.toUpperCase()}`, 'rank');
  }
  for (const a of achievements) {
    unlockQueue.push({ type: 'achievement', data: a });
    logMessage(`ACHIEVEMENT UNLOCKED — ${a.title}`, 'rank');
  }
  processUnlockQueue();
}

function processUnlockQueue() {
  if (unlockShowing || unlockQueue.length === 0) return;
  const next = unlockQueue.shift();
  showUnlockCinematic(next.type, next.data);
}

function showUnlockCinematic(type, item) {
