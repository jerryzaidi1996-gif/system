let rcaSession = {
  quest: null,       // quest object if launched from a specific quest
  driver: null,      // threat driver selected in Step 1
  currentStep: 1,
  activation: null,  // '2min' or '5min'
  commitmentMinutes: null,
  commitmentTime: null,
  tacticalData: {},  // saved input values from Step 2
  timerInterval: null,
  timerSecondsLeft: 0
};

function launchEmergencyProtocol(quest = null) {
  // Reset session
  rcaSession = {
    quest,
    driver: null,
    currentStep: 1,
    activation: null,
    commitmentMinutes: null,
    commitmentTime: null,
    tacticalData: {},
    timerInterval: null,
    timerSecondsLeft: 0
  };

  // Show/hide quest context banner
  const ctx = document.getElementById('rcaQuestContext');
  const nameEl = document.getElementById('rcaQuestName');
  if (quest) {
    ctx.style.display = '';
    nameEl.textContent = quest.name;
  } else {
    ctx.style.display = 'none';
  }

  // Reset step visibility
  showRcaStep(1);

  // Clear threat selection
  document.querySelectorAll('.rca-threat-btn').forEach(b => b.classList.remove('selected'));

  // Clear lock preset selections and custom time
  document.querySelectorAll('.rca-lock-preset').forEach(b => b.classList.remove('selected'));
  document.getElementById('rcaCustomTime').value = '';
  document.getElementById('rcaLockBtn').disabled = true;
  const preview = document.getElementById('rcaCommitmentPreview');
  preview.textContent = '『 No checkpoint set 』';
  preview.classList.remove('set');

  // Stop any existing timer
  stopRcaTimer();

  // Open overlay
  document.getElementById('rcaOverlay').classList.add('active');
}

function closeRcaModal() {
  document.getElementById('rcaOverlay').classList.remove('active');
  stopRcaTimer();
}

function showRcaStep(n) {
  rcaSession.currentStep = n;
  document.querySelectorAll('.rca-step').forEach(el => {
    el.style.display = (parseInt(el.dataset.step, 10) === n) ? '' : 'none';
  });
}

/* Step 1: Threat selection */
document.querySelectorAll('.rca-threat-btn').forEach(btn => {
