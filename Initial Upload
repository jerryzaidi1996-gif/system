/* ============ PENALTY SYSTEM ============ */
function checkPenaltyOnLoad() {
  const today = todayISO();

  // Only check once per day
  if (state.penaltyTriggeredDate === today) return;

  const now = new Date();
  const currentHour = now.getHours() + (now.getMinutes() / 60);

  // Has Jerry completed anything today?
  const completedToday = state.quests.some(q =>
    q.completed && q.completedAt && q.completedAt.substring(0, 10) === today
  );

  // Is it past the penalty trigger hour AND no quests completed?
  if (currentHour >= state.penaltyTriggerHour && !completedToday) {
    // Inject a Penalty Quest into Dungeon of Order
    const penaltyQuest = {
      id: 'q_penalty_' + Date.now(),
      name: 'PENALTY: RECALIBRATE — Plan your next 3 tasks. No excuses.',
      category: 'dungeon',
      difficulty: 'easy',
      dueTime: null,
      completed: false,
      completedAt: null,
      createdAt: new Date().toISOString(),
      source: 'penalty',
      missionType: 'penalty'
    };
    state.quests.push(penaltyQuest);
    state.penaltyTriggeredDate = today;

    logMessage('INACTIVITY DETECTED — PENALTY QUEST ASSIGNED', 'penalty');

    // Show the penalty alert modal
    setTimeout(() => showPenaltyAlert(), 600);
  }
}

function showPenaltyAlert() {
  showToast('HUNTER. INACTIVITY DETECTED. PENALTY QUEST ASSIGNED.', 'danger');
}

/* ============ OVERDUE QUEST LOGGING ============ */
function checkAndLogOverdue() {
  const now = new Date();
  for (const q of state.quests) {
    if (q.completed || !q.dueTime) continue;
    if (state.overdueLoggedIds.includes(q.id)) continue;

    const [hh, mm] = q.dueTime.split(':').map(Number);
    const due = new Date();
    due.setHours(hh, mm, 0, 0);

    if (now > due) {
      // Only log once per quest per day
      state.overdueLoggedIds.push(q.id);
      logMessage(`OVERDUE — ${q.name.toUpperCase()} · THE SYSTEM IS WATCHING`, 'overdue');
    }
  }
}

/* ============ STREAK LOGIC ============ */
function daysBetween(iso1, iso2) {
  const d1 = new Date(iso1 + 'T00:00:00');
  const d2 = new Date(iso2 + 'T00:00:00');
  return Math.round((d2 - d1) / (1000 * 60 * 60 * 24));
}

const STREAK_MILESTONES = [3, 7, 14, 30, 60, 100, 200, 365];

function updateStreakOnCompletion() {
  const today = todayISO();
  let milestone = null;

  if (state.lastStreakDate === today) {
    // already counted today
    return { milestone: null };
  }

  if (!state.lastStreakDate) {
    state.streak = 1;
  } else {
    const gap = daysBetween(state.lastStreakDate, today);
    if (gap === 1) {
      state.streak += 1;
    } else if (gap > 1) {
      // Streak broken
      state.streak = 1;
    } else {
      // gap === 0, already today, shouldn't happen due to check above
      return { milestone: null };
    }
  }

  state.lastStreakDate = today;

  if (STREAK_MILESTONES.includes(state.streak)) {
    milestone = state.streak;
  }

  return { milestone };
}

function checkStreakDecay() {
  // Called on load — if Jerry hasn't completed anything for a day, streak is at risk;
  // after 2+ days missed, streak resets to 0
  if (!state.lastStreakDate) return;
  const today = todayISO();
  const gap = daysBetween(state.lastStreakDate, today);
  if (gap >= 2 && state.streak > 0) {
    const prevStreak = state.streak;
    state.streak = 0;
    logMessage(`STREAK BROKEN — ${prevStreak}-DAY STREAK LOST. WEAKNESS NOTED.`, 'penalty');
  }
}

function completeQuest(id) {
  const q = state.quests.find(x => x.id === id);
  if (!q || q.completed) return;

  q.completed = true;
  q.completedAt = new Date().toISOString();

  const xpGained = XP_BY_DIFFICULTY[q.difficulty] || 0;
  state.totalXp += xpGained;

  // Phase 3: Award stats
  const statGains = calculateStatGains(q.category, q.difficulty);
  for (const [stat, amt] of Object.entries(statGains)) {
    state.stats[stat] = (state.stats[stat] || 0) + amt;
  }

  // Phase 4: Track lifetime progress metrics
  state.totalQuestsCompleted = (state.totalQuestsCompleted || 0) + 1;
  if (!state.questsCompletedByCategory) state.questsCompletedByCategory = { scholar: 0, research: 0, iron: 0, dungeon: 0, recovery: 0 };
  state.questsCompletedByCategory[q.category] = (state.questsCompletedByCategory[q.category] || 0) + 1;
  if (q.difficulty === 'hard') state._hardCompleted = (state._hardCompleted || 0) + 1;

  // Phase 3: Update streak
  const streakResult = updateStreakOnCompletion();
  if (state.streak > (state.maxStreakEver || 0)) state.maxStreakEver = state.streak;

  // Check for rank-up
  const newRankIdx = calculateRank(state.totalXp);
  const didRankUp = newRankIdx > state.currentRankIdx;
  const prevRank = RANKS[state.currentRankIdx].name;

  if (didRankUp) {
    state.currentRankIdx = newRankIdx;
  }

  // Build message & log
  const statText = Object.entries(statGains).map(([s, a]) => `+${a} ${s}`).join(' · ');
  const toastMsg = statText
    ? `QUEST COMPLETE. +${xpGained} EXP · ${statText}.`
    : `QUEST COMPLETE. +${xpGained} EXP ACQUIRED.`;

  logMessage(`${q.name.toUpperCase()} — +${xpGained} EXP${statText ? ' · ' + statText : ''}`, 'xp');

  // Phase 4: check for new unlocks
  checkAndUnlockProgress();

  saveState();
  render();

  showToast(toastMsg, 'accent');

  if (streakResult.milestone) {
    setTimeout(() => {
      showToast(`STREAK MILESTONE. ${streakResult.milestone} DAYS OF DISCIPLINE.`, 'accent');
      logMessage(`STREAK MILESTONE REACHED — ${streakResult.milestone} DAYS`, 'streak');
    }, 700);
  }

  if (didRankUp) {
    setTimeout(() => showRankUp(prevRank, RANKS[newRankIdx].name), 900);
    logMessage(`RANK ASCENSION — ${prevRank} → ${RANKS[newRankIdx].name}`, 'rank');
  }
}

function deleteQuest(id) {
  const q = state.quests.find(x => x.id === id);
  if (!q) return;
  state.quests = state.quests.filter(x => x.id !== id);
  logMessage(`QUEST ABANDONED — ${q.name.toUpperCase()}`, 'penalty');
  saveState();
  render();
  showToast('QUEST ABANDONED. WEAKNESS NOTED.', 'danger');
}

/* ============ TOAST NOTIFICATIONS ============ */
function showToast(message, variant = 'normal') {
  const container = document.getElementById('toastContainer');
  const toast = document.createElement('div');
  toast.className = 'toast' + (variant === 'danger' ? ' danger' : '');

  // Process message: wrap numbers like "+150 EXP" and "+2 INT" in accent
  const processed = message
    .replace(/\+(\d+)\s*EXP/g, '<span class="accent">+$1 EXP</span>')
    .replace(/\+(\d+)\s*(INT|STR|VIT|AGI|SEN)/g, '<span class="accent">+$1 $2</span>');

  toast.innerHTML = `
    <span class="corner tl"></span><span class="corner tr"></span>
    <span class="corner bl"></span><span class="corner br"></span>
    <div class="toast-header">
      <span class="alert-icon">!</span>
      <span>${variant === 'danger' ? 'System Alert' : 'System Message'}</span>
      <span class="alert-icon">!</span>
    </div>
    <div class="toast-body">${processed}</div>
  `;
  container.appendChild(toast);

  setTimeout(() => { toast.remove(); }, 3200);
}

