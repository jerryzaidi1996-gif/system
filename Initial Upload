});

/* Step 3: Activation */
document.getElementById('rcaTwoMinBtn').addEventListener('click', () => {
  rcaSession.activation = '2min';
  if (rcaSession.quest && !rcaSession.quest.completed) {
    // Shortcut: mark quest as complete via the 2-minute rule
    completeQuest(rcaSession.quest.id);
    logMessage('2-MINUTE RULE INVOKED — QUEST EXECUTED', 'xp');
  } else {
    showToast('2-MINUTE RULE. DO IT NOW.', 'accent');
  }
  closeRcaModal();
});

document.getElementById('rcaFiveMinBtn').addEventListener('click', () => {
  rcaSession.activation = '5min';
  startRcaTimer();
});

function startRcaTimer() {
  const timerEl = document.getElementById('rcaTimer');
  const display = document.getElementById('rcaTimerDisplay');
  const fill = document.getElementById('rcaTimerFill');
  timerEl.style.display = '';
  rcaSession.timerSecondsLeft = 5 * 60;
  display.textContent = '05:00';
  fill.style.width = '100%';

  rcaSession.timerInterval = setInterval(() => {
    rcaSession.timerSecondsLeft -= 1;
    if (rcaSession.timerSecondsLeft <= 0) {
      stopRcaTimer();
      display.textContent = '00:00';
      fill.style.width = '0%';
      showToast('5-MINUTE COMMITMENT FULFILLED. CONTINUE THE MOMENTUM.', 'accent');
      logMessage('5-MINUTE COMMITMENT COMPLETED', 'xp');
      state.totalXp += 20;
      state.stats.SEN = (state.stats.SEN || 0) + 1;
      saveState();
      render();
      return;
    }
    const mm = String(Math.floor(rcaSession.timerSecondsLeft / 60)).padStart(2, '0');
    const ss = String(rcaSession.timerSecondsLeft % 60).padStart(2, '0');
    display.textContent = `${mm}:${ss}`;
    const pct = (rcaSession.timerSecondsLeft / 300) * 100;
    fill.style.width = pct + '%';
  }, 1000);
}

function stopRcaTimer() {
  if (rcaSession.timerInterval) {
    clearInterval(rcaSession.timerInterval);
    rcaSession.timerInterval = null;
  }
}

document.getElementById('rcaTimerAbortBtn').addEventListener('click', () => {
