function saveCheckIn() {
  const weightEl = document.getElementById('cinWeight');
  const stepsEl = document.getElementById('cinSteps');
  const proteinEl = document.getElementById('cinProtein');
  const waterEl = document.getElementById('cinWater');

  const weight = parseFloat(weightEl.value);
  const steps = parseInt(stepsEl.value, 10);
  const protein = parseFloat(proteinEl.value);
  const water = parseFloat(waterEl.value);

  let logged = [];

  if (!isNaN(weight) && weight > 0) {
    logCheckIn('weight', weight);
    logged.push(`${weight.toFixed(1)} lb`);
  }
  if (!isNaN(steps) && steps >= 0) {
    logCheckIn('steps', steps);
    logged.push(`${steps.toLocaleString()} steps`);
  }
  if (!isNaN(protein) && protein >= 0) {
    logCheckIn('proteinG', protein);
    logged.push(`${protein}g protein`);
  }
  if (!isNaN(water) && water >= 0) {
    logCheckIn('waterL', water);
    logged.push(`${water}L water`);
  }

  if (logged.length === 0) {
    showToast('NO VALUES ENTERED. THE SYSTEM EXPECTS DATA.', 'danger');
    return;
  }

  // Award small EXP for check-in completion
  const xpGained = 15;
  state.totalXp += xpGained;
  state.stats.VIT = (state.stats.VIT || 0) + 1;

  logMessage(`CHECK-IN LOGGED — ${logged.join(' · ')} · +${xpGained} EXP`, 'xp');

  // Rank up check
  const newRankIdx = calculateRank(state.totalXp);
  const didRankUp = newRankIdx > state.currentRankIdx;
  const prevRank = RANKS[state.currentRankIdx].name;
  if (didRankUp) state.currentRankIdx = newRankIdx;

  checkAndUnlockProgress();
  saveState();
  render();

  showToast(`CHECK-IN LOGGED. +${xpGained} EXP. DISCIPLINE CONFIRMED.`, 'accent');

  if (didRankUp) {
    setTimeout(() => showRankUp(prevRank, RANKS[newRankIdx].name), 900);
  }
}

/* ============ WEIGHT CHART (SVG) ============ */
function drawWeightChart() {
  const host = document.getElementById('weightChartHost');
  if (!host) return;

  const hist = state.bodyStats.weightHistory || [];
  const start = state.bodyStats.startWeight;
  const goal = state.bodyStats.goalWeight;

  if (hist.length < 2) {
    host.innerHTML = '<div class="weight-chart-empty">『 Log weight for at least 2 days to see trajectory 』</div>';
    return;
  }

  const avgHist = getMovingAverage();

  const W = 400, H = 200;
  const padL = 36, padR = 14, padT = 14, padB = 28;
  const plotW = W - padL - padR;
  const plotH = H - padT - padB;

  const minW = Math.min(...hist.map(e => e.weight), goal || Infinity);
  const maxW = Math.max(...hist.map(e => e.weight), start || 0);
  const range = Math.max(5, maxW - minW);
  const yMin = Math.floor(minW - range * 0.1);
  const yMax = Math.ceil(maxW + range * 0.05);

  const minDate = new Date(hist[0].date).getTime();
  const maxDate = new Date(hist[hist.length - 1].date).getTime();
  const dateRange = Math.max(1, maxDate - minDate);

  const xFor = (date) => padL + ((new Date(date).getTime() - minDate) / dateRange) * plotW;
  const yFor = (w) => padT + ((yMax - w) / (yMax - yMin)) * plotH;

  // Build paths
  const rawPath = hist.map((e, i) => `${i === 0 ? 'M' : 'L'}${xFor(e.date).toFixed(1)},${yFor(e.weight).toFixed(1)}`).join(' ');
  const avgPath = avgHist.map((e, i) => `${i === 0 ? 'M' : 'L'}${xFor(e.date).toFixed(1)},${yFor(e.weight).toFixed(1)}`).join(' ');

  // Goal line
  const goalY = goal ? yFor(goal) : null;

  // Gridlines (4 horizontal)
  const gridY = [];
  for (let i = 0; i <= 4; i++) {
    const y = padT + (i / 4) * plotH;
    const val = yMax - (i / 4) * (yMax - yMin);
    gridY.push({ y, val });
  }

  // Date ticks (start, mid, end)
  const dateTicks = [];
  if (hist.length > 0) {
    dateTicks.push({ x: xFor(hist[0].date), label: fmtShortDate(hist[0].date) });
    if (hist.length > 2) {
      const mid = hist[Math.floor(hist.length / 2)];
      dateTicks.push({ x: xFor(mid.date), label: fmtShortDate(mid.date) });
    }
    dateTicks.push({ x: xFor(hist[hist.length - 1].date), label: fmtShortDate(hist[hist.length - 1].date) });
  }

  const svg = `
    <svg class="weight-chart-svg" viewBox="0 0 ${W} ${H}" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#5ce6f0" stop-opacity="0.3"/>
          <stop offset="100%" stop-color="#5ce6f0" stop-opacity="0"/>
        </linearGradient>
      </defs>

      ${gridY.map(g => `
        <line x1="${padL}" y1="${g.y.toFixed(1)}" x2="${W - padR}" y2="${g.y.toFixed(1)}" stroke="rgba(92, 230, 240, 0.1)" stroke-width="1"/>
        <text x="${padL - 6}" y="${(g.y + 3).toFixed(1)}" fill="#5d7380" font-family="Orbitron, sans-serif" font-size="9" text-anchor="end">${Math.round(g.val)}</text>
      `).join('')}

      ${dateTicks.map(t => `
        <text x="${t.x.toFixed(1)}" y="${H - padB + 16}" fill="#5d7380" font-family="Orbitron, sans-serif" font-size="8" text-anchor="middle" letter-spacing="1">${t.label}</text>
      `).join('')}

      ${goalY !== null && goalY >= padT && goalY <= padT + plotH ? `
        <line x1="${padL}" y1="${goalY.toFixed(1)}" x2="${W - padR}" y2="${goalY.toFixed(1)}" stroke="#f5c451" stroke-width="1" stroke-dasharray="4 4" opacity="0.8"/>
        <text x="${W - padR - 4}" y="${(goalY - 4).toFixed(1)}" fill="#ffd97a" font-family="Orbitron, sans-serif" font-size="8" text-anchor="end" letter-spacing="1">GOAL ${goal}</text>
      ` : ''}

      <!-- Raw weight path (light) -->
      <path d="${rawPath}" stroke="rgba(92, 230, 240, 0.35)" stroke-width="1.2" fill="none"/>

      <!-- Moving average (bold, glowing) -->
      <path d="${avgPath} L${xFor(hist[hist.length-1].date).toFixed(1)},${(padT + plotH).toFixed(1)} L${padL},${(padT + plotH).toFixed(1)} Z" fill="url(#areaGrad)" opacity="0.5"/>
      <path d="${avgPath}" stroke="#5ce6f0" stroke-width="2" fill="none" filter="drop-shadow(0 0 4px #5ce6f0)"/>

      <!-- End marker -->
      <circle cx="${xFor(hist[hist.length-1].date).toFixed(1)}" cy="${yFor(hist[hist.length-1].weight).toFixed(1)}" r="3.5" fill="#8ff4ff" stroke="#5ce6f0" stroke-width="1.5" filter="drop-shadow(0 0 6px #5ce6f0)"/>
    </svg>
  `;

  host.innerHTML = svg;
}

function fmtShortDate(iso) {
  const d = new Date(iso);
  return d.toLocaleDateString([], { month: 'short', day: 'numeric' });
}

