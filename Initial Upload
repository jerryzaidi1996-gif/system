  dismissBtn.disabled = true;
  setTimeout(() => { dismissBtn.disabled = false; }, 1800);

  dismissBtn.onclick = () => {
    overlay.classList.remove('active');
    unlockShowing = false;
    // Show next unlock if queued
    setTimeout(() => processUnlockQueue(), 400);
  };
}

