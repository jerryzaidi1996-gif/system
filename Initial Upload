/* Step 4: Accountability lock */
document.querySelectorAll('.rca-lock-preset').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.rca-lock-preset').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    const minutes = parseInt(btn.dataset.minutes, 10);
    rcaSession.commitmentMinutes = minutes;
    const target = new Date(Date.now() + minutes * 60 * 1000);
    rcaSession.commitmentTime = target.toISOString();
    document.getElementById('rcaCustomTime').value = '';
    updateCommitmentPreview();
  });
});

document.getElementById('rcaCustomTime').addEventListener('change', (e) => {
  const v = e.target.value;
  if (!v) {
    rcaSession.commitmentTime = null;
    updateCommitmentPreview();
    return;
  }
  document.querySelectorAll('.rca-lock-preset').forEach(b => b.classList.remove('selected'));
  const [hh, mm] = v.split(':').map(Number);
  const now = new Date();
  const target = new Date();
  target.setHours(hh, mm, 0, 0);
  if (target < now) target.setDate(target.getDate() + 1); // if time already passed today
  rcaSession.commitmentMinutes = Math.round((target - now) / 60000);
  rcaSession.commitmentTime = target.toISOString();
  updateCommitmentPreview();
});

function updateCommitmentPreview() {
  const preview = document.getElementById('rcaCommitmentPreview');
  const lockBtn = document.getElementById('rcaLockBtn');
  if (!rcaSession.commitmentTime) {
    preview.textContent = '『 No checkpoint set 』';
    preview.classList.remove('set');
    lockBtn.disabled = true;
    return;
  }
  const target = new Date(rcaSession.commitmentTime);
  const timeStr = target.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  const relMin = rcaSession.commitmentMinutes;
  const relStr = relMin < 60 ? `+${relMin} min` : `+${(relMin / 60).toFixed(1)} hr`;
  preview.innerHTML = `CHECKPOINT: <b>${timeStr}</b> &middot; ${relStr}`;
  preview.classList.add('set');
  lockBtn.disabled = false;
}

document.getElementById('rcaLockBtn').addEventListener('click', () => {
  lockCommitment();
});

function lockCommitment() {
  if (!rcaSession.commitmentTime) return;

  const commitment = {
    id: 'c_' + Date.now() + '_' + Math.random().toString(36).slice(2, 8),
    questId: rcaSession.quest ? rcaSession.quest.id : null,
    questName: rcaSession.quest ? rcaSession.quest.name : '(standalone)',
    driver: rcaSession.driver,
    tacticalData: rcaSession.tacticalData,
    activation: rcaSession.activation,
    checkpointTime: rcaSession.commitmentTime,
    status: 'active',    // 'active' | 'honored' | 'failed'
    createdAt: new Date().toISOString()
  };

  if (!state.commitments) state.commitments = [];
  state.commitments.push(commitment);

  if (!state.rcaSessions) state.rcaSessions = [];
  state.rcaSessions.push({
    questId: commitment.questId,
    questName: commitment.questName,
    driver: rcaSession.driver,
    timestamp: new Date().toISOString()
  });

  // Log to system feed
  const target = new Date(commitment.checkpointTime);
  const timeStr = target.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  logMessage(`COMMITMENT LOCKED — ${commitment.questName.toUpperCase()} · CHECKPOINT ${timeStr}`, 'rank');

  // Render step 5 summary
  renderLockedSummary(commitment);
  showRcaStep(5);

  saveState();
  render();
}

