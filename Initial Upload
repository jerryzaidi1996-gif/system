// E→D: ~2-3 weeks | D→C: ~1 month | C→B: ~2 months | B→A: ~3 months
// A→S: ~4 months | S→National: ~6 months | Total E→National: ~12-15 months
const RANKS = [
  { name: 'E-RANK',         threshold: 0,      title: 'THE BEGINNING' },
  { name: 'D-RANK',         threshold: 2500,   title: 'THE AWAKENED' },
  { name: 'C-RANK',         threshold: 7000,   title: 'THE HARDENED' },
  { name: 'B-RANK',         threshold: 15000,  title: 'THE RELENTLESS' },
  { name: 'A-RANK',         threshold: 28000,  title: 'THE ASCENDING' },
  { name: 'S-RANK',         threshold: 45000,  title: 'THE SOVEREIGN' },
  { name: 'NATIONAL LEVEL', threshold: 70000,  title: 'ABOVE THE SYSTEM' }
];

const XP_BY_DIFFICULTY = { easy: 15, medium: 40, hard: 80, boss: 250 };

/* ============ STAT GAIN MAPPING ============ */
// Each category awards stats on quest completion. Base values for medium difficulty;
// scale by difficulty multiplier (easy=0.5x, medium=1x, hard=2x, boss=5x).
const STAT_GAINS_BY_CATEGORY = {
  scholar:  { INT: 2 },
  research: { INT: 2 },
  iron:     { STR: 2, VIT: 1 },
  dungeon:  { AGI: 2 },
  recovery: { VIT: 2, SEN: 2 }
};
const DIFFICULTY_MULTIPLIER = { easy: 0.5, medium: 1, hard: 2, boss: 5 };

function calculateStatGains(category, difficulty) {
  const base = STAT_GAINS_BY_CATEGORY[category] || {};
  const mult = DIFFICULTY_MULTIPLIER[difficulty] || 1;
  const result = {};
  for (const [stat, amt] of Object.entries(base)) {
    result[stat] = Math.max(1, Math.round(amt * mult));
  }
  return result;
}

/* ═══════════════════════════════════════════════════════
   FORGE THE BODY — Transformation System
   ═══════════════════════════════════════════════════════ */

function ensureBodyStats() {
  if (!state.bodyStats) {
    state.bodyStats = {
      startWeight: null,
      startDate: null,
      goalWeight: null,
      goalPaceLbPerWeek: 2,
      safetyWarnings: false,
      weightHistory: [],
      measurements: [],
      dailyCheckIns: {},
      configured: false
    };
  }
  // Ensure subfields exist
  if (!state.bodyStats.weightHistory) state.bodyStats.weightHistory = [];
  if (!state.bodyStats.measurements) state.bodyStats.measurements = [];
  if (!state.bodyStats.dailyCheckIns) state.bodyStats.dailyCheckIns = {};
}

function logWeight(weight) {
  ensureBodyStats();
  const today = todayISO();

  // Update today's entry or add new
  const existing = state.bodyStats.weightHistory.find(e => e.date === today);
  if (existing) {
    existing.weight = weight;
  } else {
    state.bodyStats.weightHistory.push({ date: today, weight });
    state.bodyStats.weightHistory.sort((a, b) => a.date.localeCompare(b.date));
  }

  // If this is the first weight ever logged, set start
  if (!state.bodyStats.startWeight) {
    state.bodyStats.startWeight = weight;
    state.bodyStats.startDate = today;
  }

  // Update today's daily check-in
  if (!state.bodyStats.dailyCheckIns[today]) state.bodyStats.dailyCheckIns[today] = {};
  state.bodyStats.dailyCheckIns[today].weight = weight;

  // Milestone check
  checkWeightMilestones();
}

function logCheckIn(field, value) {
  ensureBodyStats();
  const today = todayISO();
  if (!state.bodyStats.dailyCheckIns[today]) state.bodyStats.dailyCheckIns[today] = {};
  state.bodyStats.dailyCheckIns[today][field] = value;

  if (field === 'weight') {
    logWeight(value);
  }
}

function logMeasurements(data) {
  ensureBodyStats();
  const today = todayISO();
  const existing = state.bodyStats.measurements.find(m => m.date === today);
  if (existing) {
    Object.assign(existing, data);
  } else {
    state.bodyStats.measurements.push({ date: today, ...data });
    state.bodyStats.measurements.sort((a, b) => a.date.localeCompare(b.date));
  }
  logMessage(`MEASUREMENTS LOGGED — ${today}`, 'info');
}

function getLatestWeight() {
  ensureBodyStats();
  const hist = state.bodyStats.weightHistory;
  if (hist.length === 0) return null;
  return hist[hist.length - 1].weight;
}

function getWeightLost() {
  if (!state.bodyStats.startWeight) return 0;
  const latest = getLatestWeight();
  if (!latest) return 0;
  return state.bodyStats.startWeight - latest;
}

function getWeightLossPercent() {
  if (!state.bodyStats.startWeight) return 0;
  return (getWeightLost() / state.bodyStats.startWeight) * 100;
}

// 4-week rolling pace in lb/week
function getCurrentPace() {
  const hist = state.bodyStats.weightHistory;
  if (hist.length < 2) return 0;

  const now = new Date();
  const fourWeeksAgo = new Date(now.getTime() - 28 * 24 * 60 * 60 * 1000);

  const recent = hist.filter(e => new Date(e.date) >= fourWeeksAgo);
  if (recent.length < 2) {
    // Use full history if we don't have enough recent data
    const first = hist[0];
    const last = hist[hist.length - 1];
    const weeks = (new Date(last.date) - new Date(first.date)) / (7 * 24 * 60 * 60 * 1000);
    if (weeks < 0.5) return 0;
    return (first.weight - last.weight) / weeks;
  }

  const first = recent[0];
  const last = recent[recent.length - 1];
  const weeks = (new Date(last.date) - new Date(first.date)) / (7 * 24 * 60 * 60 * 1000);
  if (weeks < 0.5) return 0;
  return (first.weight - last.weight) / weeks;
}

// 7-day moving average for smoothing weight chart
function getMovingAverage() {
  const hist = state.bodyStats.weightHistory;
  const result = [];
  for (let i = 0; i < hist.length; i++) {
    const window = hist.slice(Math.max(0, i - 6), i + 1);
    const avg = window.reduce((sum, e) => sum + e.weight, 0) / window.length;
    result.push({ date: hist[i].date, weight: avg });
  }
  return result;
}

function projectedGoalDate() {
  if (!state.bodyStats.goalWeight) return null;
  const latest = getLatestWeight();
  if (!latest || latest <= state.bodyStats.goalWeight) return null;
  const pace = getCurrentPace();
  if (pace <= 0) return null;
  const remaining = latest - state.bodyStats.goalWeight;
  const weeksToGo = remaining / pace;
  const result = new Date();
  result.setDate(result.getDate() + Math.round(weeksToGo * 7));
  return result;
}

function projectedGoalDateAtTargetPace() {
  if (!state.bodyStats.goalWeight || !state.bodyStats.startWeight) return null;
  const latest = getLatestWeight() || state.bodyStats.startWeight;
  if (latest <= state.bodyStats.goalWeight) return null;
  const pace = state.bodyStats.goalPaceLbPerWeek || 2;
  const remaining = latest - state.bodyStats.goalWeight;
  const weeksToGo = remaining / pace;
  const result = new Date();
  result.setDate(result.getDate() + Math.round(weeksToGo * 7));
  return result;
}

