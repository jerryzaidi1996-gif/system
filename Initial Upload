/* ============ DIRECTIVE GENERATION ============ */
// The System assigns missions based on your rank tier.
// Tier 0-1 missions phase out as you climb (they become too easy).
// Tier N+1 becomes available at each rank to keep pushing difficulty up.

function getTierRangeForRank(rankIdx) {
  // Returns [minTier, maxTier] inclusive for available missions at this rank
  // E-Rank(0): tiers 0-1 | D(1): 0-2 | C(2): 1-3 | B(3): 2-4 | A(4): 2-4 | S+(5+): 3-4
  const ranges = [
    [0, 1],  // E
    [0, 2],  // D
    [1, 3],  // C
    [2, 4],  // B
    [2, 4],  // A
    [3, 4],  // S
    [3, 4],  // National
  ];
  return ranges[Math.min(rankIdx, ranges.length - 1)];
}

function pickMissionsForCategory(category, rankIdx, count, excludeTexts = []) {
  const pool = MISSION_LIBRARY[category] || [];
  const [minTier, maxTier] = getTierRangeForRank(rankIdx);
  const eligible = pool.filter(m =>
    m.tier >= minTier &&
    m.tier <= maxTier &&
    m.d !== 'boss' &&
    !excludeTexts.includes(m.text)
  );

  // Shuffle
  const shuffled = [...eligible].sort(() => Math.random() - 0.5);
  return shuffled.slice(0, count);
}

function generateDailyDirectives(rankIdx) {
  // 3 mandatory Daily Directives: 1 easy, 1 medium, 1 hard where possible
  // Pulled from 3 different categories for variety.
  const categories = Object.keys(MISSION_LIBRARY);
  const shuffledCats = [...categories].sort(() => Math.random() - 0.5);
  const directives = [];
  const usedTexts = [];

  const targetDifficulties = ['easy', 'medium', 'hard'];

  for (let i = 0; i < 3; i++) {
    const cat = shuffledCats[i % shuffledCats.length];
    const [minTier, maxTier] = getTierRangeForRank(rankIdx);
    const targetDiff = targetDifficulties[i];

    const pool = MISSION_LIBRARY[cat].filter(m =>
      m.tier >= minTier &&
      m.tier <= maxTier &&
      m.d === targetDiff &&
      !usedTexts.includes(m.text)
    );

    let chosen;
    if (pool.length > 0) {
      chosen = pool[Math.floor(Math.random() * pool.length)];
    } else {
      // Fallback: any eligible mission of any difficulty
      const fallback = pickMissionsForCategory(cat, rankIdx, 1, usedTexts);
      chosen = fallback[0];
    }

    if (chosen) {
      directives.push({ ...chosen, category: cat });
      usedTexts.push(chosen.text);
    }
  }

  return directives;
}

function generateSideQuests(rankIdx, excludeTexts = []) {
  // 5 optional side quests, one from each category
  const categories = Object.keys(MISSION_LIBRARY);
  const sideQuests = [];
  const used = [...excludeTexts];

  for (const cat of categories) {
    const missions = pickMissionsForCategory(cat, rankIdx, 1, used);
    if (missions.length > 0) {
      sideQuests.push({ ...missions[0], category: cat });
      used.push(missions[0].text);
    }
  }

  return sideQuests;
}

