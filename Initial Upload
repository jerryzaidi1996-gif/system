letter-spacing: 0.35em;
color: var(–accent-cyan-bright);
text-shadow: 0 0 8px var(–accent-cyan);
text-align: center;
margin-bottom: 6px;
text-transform: uppercase;
}

.emergency-launch-subtitle {
font-family: ‘Orbitron’, sans-serif;
font-size: 10px;
letter-spacing: 0.25em;
color: var(–text-dim);
text-align: center;
margin-bottom: 18px;
text-transform: uppercase;
}

.emergency-quest-list {
display: flex;
flex-direction: column;
gap: 6px;
max-height: 260px;
overflow-y: auto;
margin-bottom: 14px;
}

.emergency-quest-item {
display: flex;
align-items: center;
justify-content: space-between;
gap: 10px;
padding: 10px 14px;
background: rgba(2, 3, 9, 0.6);
border: 1px solid var(–border-dim);
cursor: pointer;
transition: all 0.2s;
}

.emergency-quest-item:hover {
border-color: var(–danger);
background: rgba(255, 71, 87, 0.06);
}

.emergency-quest-item-name {
font-family: ‘JetBrains Mono’, monospace;
font-size: 12px;
color: var(–text-primary);
flex: 1;
min-width: 0;
overflow: hidden;
text-overflow: ellipsis;
white-space: nowrap;
letter-spacing: 0.02em;
}

.emergency-quest-item-btn {
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: 9.5px;
letter-spacing: 0.25em;
padding: 5px 10px;
border: 1px solid var(–danger);
color: var(–danger);
background: transparent;
text-shadow: 0 0 4px var(–danger);
flex-shrink: 0;
text-transform: uppercase;
}

.emergency-quest-list-empty {
text-align: center;
padding: 20px 14px;
font-family: ‘Orbitron’, sans-serif;
font-size: 10px;
letter-spacing: 0.3em;
color: var(–text-faint);
text-transform: uppercase;
}

.emergency-launch-btn {
width: 100%;
padding: 12px;
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: 11px;
letter-spacing: 0.4em;
text-transform: uppercase;
background: transparent;
border: 1px dashed var(–border-mid);
color: var(–text-secondary);
cursor: pointer;
transition: all 0.2s;
}

.emergency-launch-btn:hover {
border-color: var(–accent-cyan);
color: var(–accent-cyan-bright);
text-shadow: 0 0 6px var(–accent-cyan);
background: rgba(92, 230, 240, 0.05);
}

/* Active commitments panel */
.commitments-panel,
.rca-history-panel {
position: relative;
background: var(–bg-panel);
border: 1px solid var(–border-dim);
padding: 16px 20px;
margin-bottom: 20px;
backdrop-filter: blur(10px);
}

.commitments-title,
.rca-history-title {
font-family: ‘Orbitron’, sans-serif;
font-weight: 700;
font-size: 11px;
letter-spacing: 0.35em;
color: var(–accent-cyan);
text-shadow: 0 0 4px var(–accent-cyan);
text-transform: uppercase;
margin-bottom: 14px;
}

.commitment-row {
display: flex;
align-items: center;
justify-content: space-between;
gap: 12px;
padding: 10px 14px;
margin-bottom: 6px;
background: rgba(2, 3, 9, 0.6);
border: 1px solid var(–border-dim);
border-left: 2px solid var(–accent-cyan);
}

.commitment-row.overdue {
border-left-color: var(–danger);
background: rgba(255, 71, 87, 0.06);
}

.commitment-row.honored {
border-left-color: var(–success);
opacity: 0.6;
}

.commitment-row.failed {
border-left-color: var(–danger);
opacity: 0.5;
}

.commitment-info {
flex: 1;
min-width: 0;
}

.commitment-action {
font-family: ‘JetBrains Mono’, monospace;
font-size: 12px;
color: var(–text-primary);
letter-spacing: 0.02em;
margin-bottom: 3px;
overflow: hidden;
text-overflow: ellipsis;
white-space: nowrap;
}

.commitment-meta {
font-family: ‘Orbitron’, sans-serif;
font-size: 9px;
letter-spacing: 0.2em;
color: var(–text-dim);
text-transform: uppercase;
}

.commitment-meta .time {
color: var(–accent-cyan);
text-shadow: 0 0 3px var(–accent-cyan);
}

.commitment-row.overdue .commitment-meta .time {
color: var(–danger);
text-shadow: 0 0 3px var(–danger);
}

.commitment-actions {
display: flex;
gap: 6px;
flex-shrink: 0;
}

.commitment-btn {
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: 9px;
letter-spacing: 0.22em;
padding: 5px 10px;
border: 1px solid;
background: transparent;
cursor: pointer;
transition: all 0.2s;
text-transform: uppercase;
}

.commitment-btn.honor {
border-color: var(–success);
color: var(–success);
text-shadow: 0 0 4px var(–success);
}

.commitment-btn.fail {
border-color: var(–danger);
color: var(–danger);
text-shadow: 0 0 4px var(–danger);
}

.commitments-empty,
.rca-history-empty {
text-align: center;
padding: 14px;
font-family: ‘Orbitron’, sans-serif;
font-size: 10px;
letter-spacing: 0.3em;
color: var(–text-faint);
text-transform: uppercase;
}

.rca-history-row {
display: flex;
align-items: center;
justify-content: space-between;
gap: 10px;
padding: 8px 12px;
margin-bottom: 4px;
background: rgba(2, 3, 9, 0.5);
border: 1px solid var(–border-dim);
font-family: ‘JetBrains Mono’, monospace;
font-size: 11px;
color: var(–text-secondary);
}

.rca-history-row .meta {
font-family: ‘Orbitron’, sans-serif;
font-size: 9px;
letter-spacing: 0.15em;
color: var(–text-dim);
text-transform: uppercase;
}

/* ============ RCA MODAL ============ */
.rca-overlay {
position: fixed;
inset: 0;
z-index: 550;
background: rgba(2, 3, 9, 0.9);
backdrop-filter: blur(8px);
display: flex;
align-items: center;
justify-content: center;
padding: 20px;
opacity: 0;
visibility: hidden;
transition: opacity 0.3s, visibility 0.3s;
}

.rca-overlay.active {
opacity: 1;
visibility: visible;
}

.rca-window {
position: relative;
width: 100%;
max-width: 640px;
max-height: 92vh;
overflow-y: auto;
background: var(–bg-panel);
border: 2px solid var(–danger);
outline: 1px solid var(–danger);
outline-offset: 4px;
box-shadow: 0 0 30px rgba(255, 71, 87, 0.5), 0 0 80px rgba(255, 71, 87, 0.25);
transform: scale(0.94);
transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}

.rca-overlay.active .rca-window {
transform: scale(1);
}

.rca-window .corner {
position: absolute;
width: 16px;
height: 16px;
border-color: var(–danger);
pointer-events: none;
}
.rca-window .corner.tl { top: -3px; left: -3px; border-top: 3px solid; border-left: 3px solid; }
.rca-window .corner.tr { top: -3px; right: -3px; border-top: 3px solid; border-right: 3px solid; }
.rca-window .corner.bl { bottom: -3px; left: -3px; border-bottom: 3px solid; border-left: 3px solid; }
.rca-window .corner.br { bottom: -3px; right: -3px; border-bottom: 3px solid; border-right: 3px solid; }

.rca-header {
display: flex;
align-items: center;
justify-content: center;
gap: 10px;
padding: 10px 20px;
background: linear-gradient(180deg, rgba(255, 71, 87, 0.25), rgba(255, 71, 87, 0.06));
border-bottom: 2px solid var(–danger);
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: 11px;
letter-spacing: 0.5em;
color: #ff8f9c;
text-shadow: 0 0 10px var(–danger);
text-transform: uppercase;
}

.rca-header .alert-icon {
border-color: #ff8f9c;
color: #ff8f9c;
box-shadow: 0 0 8px var(–danger);
}

.rca-body {
padding: 22px 26px 26px;
}

.rca-quest-context {
padding: 10px 14px;
margin-bottom: 18px;
background: rgba(255, 71, 87, 0.08);
border: 1px solid rgba(255, 71, 87, 0.4);
border-left: 3px solid var(–danger);
}

.rca-quest-context-label {
font-family: ‘Orbitron’, sans-serif;
font-size: 9px;
letter-spacing: 0.3em;
color: var(–danger);
text-shadow: 0 0 4px var(–danger);
text-transform: uppercase;
margin-bottom: 3px;
}

.rca-quest-context-name {
font-family: ‘JetBrains Mono’, monospace;
font-size: 13px;
color: var(–text-primary);
letter-spacing: 0.02em;
}

.rca-step {
animation: rca-step-in 0.4s ease;
}

@keyframes rca-step-in {
from { opacity: 0; transform: translateY(12px); }
to   { opacity: 1; transform: translateY(0); }
}

.rca-step-header {
display: flex;
align-items: center;
gap: 14px;
margin-bottom: 14px;
padding-bottom: 10px;
border-bottom: 1px solid var(–border-dim);
}

.rca-step-num {
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: 28px;
letter-spacing: 0.05em;
color: var(–danger);
text-shadow: 0 0 8px var(–danger);
}

.rca-step-title {
font-family: ‘Orbitron’, sans-serif;
font-weight: 700;
font-size: 14px;
letter-spacing: 0.3em;
color: var(–text-primary);
text-transform: uppercase;
}

.rca-step-prompt {
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: 16px;
letter-spacing: 0.25em;
color: #ff8f9c;
text-shadow: 0 0 6px var(–danger);
text-align: center;
margin-bottom: 10px;
text-transform: uppercase;
}

.rca-step-instruction {
font-family: ‘Orbitron’, sans-serif;
font-size: 11px;
letter-spacing: 0.2em;
color: var(–text-secondary);
text-align: center;
margin-bottom: 18px;
text-transform: uppercase;
}

/* Step 1: Threat grid */
.rca-threat-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
gap: 10px;
}

.rca-threat-btn {
padding: 16px 14px;
background: rgba(2, 3, 9, 0.7);
border: 1px solid var(–border-dim);
color: var(–text-primary);
cursor: pointer;
transition: all 0.25s;
text-align: left;
}

.rca-threat-btn:hover {
border-color: var(–danger);
background: rgba(255, 71, 87, 0.06);
transform: translateY(-2px);
}

.rca-threat-name {
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: 13px;
letter-spacing: 0.25em;
color: var(–text-primary);
margin-bottom: 4px;
text-transform: uppercase;
}

.rca-threat-btn:hover .rca-threat-name {
color: #ff8f9c;
text-shadow: 0 0 4px var(–danger);
}

.rca-threat-desc {
font-family: ‘JetBrains Mono’, monospace;
font-size: 10.5px;
color: var(–text-dim);
letter-spacing: 0.02em;
line-height: 1.4;
}

/* Step 2: Tactical */
.rca-tactical-body {
padding: 16px 18px;
background: rgba(2, 3, 9, 0.6);
border: 1px solid var(–border-dim);
border-left: 3px solid var(–danger);
margin-bottom: 20px;
}

.rca-tactical-body p {
font-family: ‘JetBrains Mono’, monospace;
font-size: 12px;
color: var(–text-primary);
line-height: 1.6;
letter-spacing: 0.02em;
margin-bottom: 12px;
}

.rca-tactical-body p:last-child {
margin-bottom: 0;
}

.rca-tactical-body .system-line {
font-family: ‘Orbitron’, sans-serif;
font-weight: 700;
font-size: 11px;
letter-spacing: 0.2em;
color: #ff8f9c;
text-shadow: 0 0 4px var(–danger);
text-transform: uppercase;
margin-bottom: 10px;
}

.rca-tactical-input {
width: 100%;
padding: 10px 12px;
margin-bottom: 8px;
background: rgba(2, 3, 9, 0.8);
border: 1px solid var(–border-dim);
color: var(–text-primary);
font-family: ‘JetBrains Mono’, monospace;
font-size: 12px;
outline: none;
}

.rca-tactical-input:focus {
border-color: var(–danger);
box-shadow: 0 0 6px rgba(255, 71, 87, 0.4);
}

.rca-tactical-input-label {
font-family: ‘Orbitron’, sans-serif;
font-size: 9.5px;
letter-spacing: 0.25em;
color: var(–text-dim);
text-transform: uppercase;
margin-bottom: 4px;
display: block;
}

/* Step 3: Activation */
.rca-activation-options {
display: grid;
grid-template-columns: 1fr;
gap: 10px;
margin-bottom: 20px;
}

.rca-activation-btn {
padding: 18px 20px;
background: rgba(2, 3, 9, 0.7);
border: 1px solid var(–border-dim);
color: var(–text-primary);
cursor: pointer;
transition: all 0.25s;
text-align: center;
}

.rca-activation-btn:hover {
border-color: var(–danger);
background: rgba(255, 71, 87, 0.06);
}

.rca-activation-btn.primary {
border-color: var(–danger);
background: rgba(255, 71, 87, 0.1);
}

.rca-activation-btn.primary:hover {
background: rgba(255, 71, 87, 0.2);
box-shadow: 0 0 18px rgba(255, 71, 87, 0.5);
}

.rca-activation-title {
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: 14px;
letter-spacing: 0.3em;
color: var(–text-primary);
margin-bottom: 4px;
text-transform: uppercase;
}

.rca-activation-btn.primary .rca-activation-title {
color: #ff8f9c;
text-shadow: 0 0 6px var(–danger);
}

.rca-activation-desc {
font-family: ‘JetBrains Mono’, monospace;
font-size: 10.5px;
color: var(–text-dim);
letter-spacing: 0.02em;
}

/* Active 5-min timer */
.rca-timer {
margin: 20px 0 18px;
padding: 22px 20px;
background: rgba(255, 71, 87, 0.08);
border: 2px solid var(–danger);
text-align: center;
animation: timer-pulse-border 2s ease-in-out infinite;
}

@keyframes timer-pulse-border {
0%, 100% { box-shadow: 0 0 14px rgba(255, 71, 87, 0.35); }
50%      { box-shadow: 0 0 26px rgba(255, 71, 87, 0.6); }
}

.rca-timer-label {
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: 10px;
letter-spacing: 0.45em;
color: #ff8f9c;
text-shadow: 0 0 6px var(–danger);
margin-bottom: 10px;
text-transform: uppercase;
}

.rca-timer-display {
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: 54px;
letter-spacing: 0.1em;
color: var(–danger);
text-shadow: 0 0 18px var(–danger);
margin-bottom: 14px;
}

.rca-timer-bar {
width: 100%;
height: 6px;
background: rgba(255, 71, 87, 0.15);
border: 1px solid rgba(255, 71, 87, 0.4);
position: relative;
overflow: hidden;
margin-bottom: 12px;
}

.rca-timer-fill {
position: absolute;
inset: 0;
width: 100%;
background: linear-gradient(90deg, var(–danger), #ff8f9c);
box-shadow: 0 0 8px var(–danger);
transition: width 1s linear;
}

.rca-timer-message {
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: 11px;
letter-spacing: 0.4em;
color: var(–text-primary);
margin-bottom: 14px;
text-transform: uppercase;
}

.rca-timer-abort {
font-family: ‘Orbitron’, sans-serif;
font-weight: 700;
font-size: 9.5px;
letter-spacing: 0.25em;
padding: 6px 14px;
border: 1px solid var(–text-faint);
background: transparent;
color: var(–text-faint);
cursor: pointer;
transition: all 0.2s;
text-transform: uppercase;
}

.rca-timer-abort:hover {
border-color: var(–danger);
color: var(–danger);
}

/* Step 4: Accountability lock */
.rca-lock-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
gap: 8px;
margin-bottom: 16px;
}

.rca-lock-preset {
padding: 12px 10px;
background: rgba(2, 3, 9, 0.7);
border: 1px solid var(–border-dim);
color: var(–text-secondary);
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: 11px;
letter-spacing: 0.25em;
cursor: pointer;
transition: all 0.2s;
text-transform: uppercase;
}

.rca-lock-preset:hover {
border-color: var(–danger);
color: var(–text-primary);
}

.rca-lock-preset.selected {
border-color: var(–danger);
color: #ff8f9c;
text-shadow: 0 0 4px var(–danger);
background: rgba(255, 71, 87, 0.1);
}

.rca-custom-time {
margin-bottom: 16px;
}

.rca-commitment-preview {
padding: 14px 16px;
background: rgba(2, 3, 9, 0.7);
border: 1px solid var(–border-dim);
margin-bottom: 18px;
font-family: ‘Orbitron’, sans-serif;
font-size: 11px;
letter-spacing: 0.2em;
color: var(–text-secondary);
text-align: center;
text-transform: uppercase;
}

.rca-commitment-preview.set {
border-color: var(–danger);
color: #ff8f9c;
text-shadow: 0 0 4px var(–danger);
background: rgba(255, 71, 87, 0.08);
}

/* Step 5: Locked */
.rca-locked-header {
text-align: center;
margin-bottom: 22px;
}

.rca-locked-icon {
font-size: 42px;
color: var(–danger);
text-shadow: 0 0 14px var(–danger);
margin-bottom: 12px;
animation: locked-icon-pulse 2s ease-in-out infinite;
}

@keyframes locked-icon-pulse {
0%, 100% { transform: scale(1); text-shadow: 0 0 10px var(–danger); }
50%      { transform: scale(1.1); text-shadow: 0 0 20px var(–danger), 0 0 30px var(–danger); }
}

.rca-locked-title {
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: 18px;
letter-spacing: 0.4em;
color: #ff8f9c;
text-shadow: 0 0 8px var(–danger);
margin-bottom: 6px;
text-transform: uppercase;
}

.rca-locked-subtitle {
font-family: ‘Orbitron’, sans-serif;
font-size: 10px;
letter-spacing: 0.25em;
color: var(–text-dim);
text-transform: uppercase;
}

.rca-locked-summary {
padding: 16px 18px;
background: rgba(2, 3, 9, 0.7);
border: 1px solid var(–border-dim);
border-left: 3px solid var(–danger);
margin-bottom: 18px;
font-family: ‘JetBrains Mono’, monospace;
font-size: 12px;
line-height: 1.7;
color: var(–text-primary);
letter-spacing: 0.02em;
}

.rca-locked-summary .label {
font-family: ‘Orbitron’, sans-serif;
font-weight: 700;
font-size: 9.5px;
letter-spacing: 0.25em;
color: var(–danger);
text-shadow: 0 0 4px var(–danger);
margin-right: 8px;
text-transform: uppercase;
}

.rca-locked-message {
font-family: ‘Orbitron’, sans-serif;
font-weight: 700;
font-size: 11px;
letter-spacing: 0.3em;
color: var(–text-secondary);
text-align: center;
margin-bottom: 20px;
text-transform: uppercase;
line-height: 1.7;
}

.rca-close-btn {
display: block;
width: 100%;
padding: 12px;
background: rgba(255, 71, 87, 0.12);
border: 1px solid var(–danger);
color: #ff8f9c;
text-shadow: 0 0 8px var(–danger);
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: 12px;
letter-spacing: 0.5em;
cursor: pointer;
transition: all 0.2s;
text-transform: uppercase;
}

.rca-close-btn:hover {
background: rgba(255, 71, 87, 0.22);
box-shadow: 0 0 20px rgba(255, 71, 87, 0.5);
}

/* Shared step action bar */
.rca-step-actions {
display: flex;
justify-content: space-between;
gap: 10px;
margin-top: 18px;
}

.rca-back-btn,
.rca-next-btn {
padding: 10px 20px;
font-family: ‘Orbitron’, sans-serif;
font-weight: 700;
font-size: 10.5px;
letter-spacing: 0.3em;
background: transparent;
cursor: pointer;
transition: all 0.2s;
text-transform: uppercase;
}

.rca-back-btn {
border: 1px solid var(–text-faint);
color: var(–text-dim);
}

.rca-back-btn:hover {
border-color: var(–text-secondary);
color: var(–text-secondary);
}

.rca-next-btn {
border: 1px solid var(–danger);
color: #ff8f9c;
text-shadow: 0 0 4px var(–danger);
background: rgba(255, 71, 87, 0.08);
flex: 1;
max-width: 280px;
margin-left: auto;
}

.rca-next-btn:hover:not(:disabled) {
background: rgba(255, 71, 87, 0.2);
box-shadow: 0 0 12px rgba(255, 71, 87, 0.4);
}

.rca-next-btn:disabled {
opacity: 0.35;
cursor: not-allowed;
}

/* Quest row “STUCK” button */
.stuck-btn {
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: 10px;
padding: 0;
width: 26px;
height: 26px;
border: 1px solid rgba(255, 71, 87, 0.4);
background: transparent;
color: rgba(255, 143, 156, 0.7);
cursor: pointer;
transition: all 0.2s;
display: flex;
align-items: center;
justify-content: center;
flex-shrink: 0;
}

.stuck-btn:hover {
border-color: var(–danger);
color: #ff8f9c;
text-shadow: 0 0 4px var(–danger);
background: rgba(255, 71, 87, 0.1);
}

/* Mobile */
@media (max-width: 880px) {
.rca-step-num { font-size: 22px; }
.rca-step-title { font-size: 12px; }
.rca-step-prompt { font-size: 14px; letter-spacing: 0.18em; }
.rca-timer-display { font-size: 40px; }
.rca-threat-grid { grid-template-columns: 1fr; }
.rca-body { padding: 16px 18px 20px; }
.rca-window { max-height: 95vh; }
}

/* Selection */
::selection {
background: rgba(92, 230, 240, 0.35);
color: var(–text-primary);
}

/* Scrollbar */
::-webkit-scrollbar { width: 8px; }
::-webkit-scrollbar-track { background: var(–bg-void); }
