/* ============ COMMITMENT MANAGEMENT ============ */
function honorCommitment(id) {
  const c = state.commitments.find(x => x.id === id);
  if (!c || c.status !== 'active') return;
  c.status = 'honored';
  c.completedAt = new Date().toISOString();
  state.totalXp += 50;
  state.stats.SEN = (state.stats.SEN || 0) + 2;
  logMessage(`COMMITMENT HONORED — ${c.questName.toUpperCase()} · +50 EXP`, 'rank');
  saveState();
  render();
  showToast('COMMITMENT HONORED. +50 EXP. DISCIPLINE CONFIRMED.', 'accent');
}

function failCommitment(id) {
  const c = state.commitments.find(x => x.id === id);
  if (!c || c.status !== 'active') return;
  c.status = 'failed';
  c.completedAt = new Date().toISOString();
  logMessage(`COMMITMENT FAILED — ${c.questName.toUpperCase()} · THE SYSTEM REMEMBERS`, 'penalty');
  saveState();
  render();
  showToast('COMMITMENT FAILED. THE SYSTEM REMEMBERS.', 'danger');
}

function checkOverdueCommitments() {
  if (!state.commitments) return;
  const now = new Date();
  let logged = false;
  for (const c of state.commitments) {
    if (c.status !== 'active') continue;
    const checkpoint = new Date(c.checkpointTime);
    if (now > checkpoint && !c._overdueLoggedAt) {
      c._overdueLoggedAt = now.toISOString();
      logMessage(`CHECKPOINT MISSED — ${c.questName.toUpperCase()} · AWAITING RESOLUTION`, 'overdue');
      logged = true;
    }
  }
  if (logged) saveState();
}

/* ============ PHASE 5 RENDERING ============ */
function renderEmergencyTab() {
  // Only render if the tab is visible
  const panel = document.querySelector('.tab-content[data-tab-content="emergency"]');
  if (!panel) return;

  // Render active quest list for launching protocol
  const qList = document.getElementById('emergencyQuestList');
  if (qList) {
    qList.innerHTML = '';
    const activeQuests = state.quests.filter(q => !q.completed);
    if (activeQuests.length === 0) {
      qList.innerHTML = '<div class="emergency-quest-list-empty">『 No active quests 』</div>';
    } else {
      for (const q of activeQuests) {
        const row = document.createElement('div');
        row.className = 'emergency-quest-item';
        row.innerHTML = `
          <div class="emergency-quest-item-name">${escapeHtml(q.name)}</div>
          <button class="emergency-quest-item-btn">LAUNCH</button>
        `;
        row.addEventListener('click', () => launchEmergencyProtocol(q));
        qList.appendChild(row);
      }
    }
  }

  // Render commitments
  const cPanel = document.getElementById('commitmentsPanel');
  if (cPanel) {
    const allCommitments = (state.commitments || []).slice().reverse();
    const active = allCommitments.filter(c => c.status === 'active');
    const past = allCommitments.filter(c => c.status !== 'active').slice(0, 10);

    let html = '<div class="commitments-title">⚔ Active Commitments</div>';
    if (active.length === 0) {
      html += '<div class="commitments-empty">『 No active commitments 』</div>';
    } else {
      for (const c of active) {
        const target = new Date(c.checkpointTime);
        const now = new Date();
        const isOver = now > target;
        const timeStr = target.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        const dateStr = target.toLocaleDateString([], { month: 'short', day: 'numeric' });
        const cls = isOver ? 'commitment-row overdue' : 'commitment-row';

        html += `
          <div class="${cls}" data-cid="${c.id}">
            <div class="commitment-info">
              <div class="commitment-action">${escapeHtml(c.questName)}</div>
              <div class="commitment-meta">Checkpoint: <span class="time">${timeStr} · ${dateStr}</span>${isOver ? ' · OVERDUE' : ''}</div>
            </div>
            <div class="commitment-actions">
              <button class="commitment-btn honor" data-honor="${c.id}">Honor</button>
              <button class="commitment-btn fail" data-fail="${c.id}">Fail</button>
            </div>
          </div>
        `;
      }
    }
    cPanel.innerHTML = html;

    cPanel.querySelectorAll('[data-honor]').forEach(b => {
      b.addEventListener('click', () => honorCommitment(b.dataset.honor));
    });
    cPanel.querySelectorAll('[data-fail]').forEach(b => {
      b.addEventListener('click', () => failCommitment(b.dataset.fail));
    });
  }

  // Render history
  const hPanel = document.getElementById('rcaHistoryPanel');
  if (hPanel) {
    const past = (state.commitments || []).filter(c => c.status !== 'active').slice(-10).reverse();
    let html = '<div class="rca-history-title">⚔ Commitment History</div>';
    if (past.length === 0) {
      html += '<div class="rca-history-empty">『 No past commitments 』</div>';
    } else {
      for (const c of past) {
        const target = new Date(c.checkpointTime);
        const ts = target.toLocaleString([], { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
        const statusColor = c.status === 'honored' ? 'var(--success)' : 'var(--danger)';
        html += `
          <div class="rca-history-row">
            <div>${escapeHtml(c.questName)}</div>
            <div class="meta" style="color: ${statusColor};">${c.status.toUpperCase()} · ${ts}</div>
          </div>
        `;
      }
    }
    hPanel.innerHTML = html;
  }
}

document.getElementById('emergencyGenericBtn')?.addEventListener('click', () => {
  launchEmergencyProtocol(null);
});

function escapeHtml(s) {
  if (s == null) return '';
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

/* ═══════════════════════════════════════════════════════
   SETTINGS MODAL — System Configuration
   Penalty hour · Export JSON · Import JSON · Reset
   ═══════════════════════════════════════════════════════ */

const settingsToggle     = document.getElementById('settingsToggle');
const settingsModal      = document.getElementById('settingsModal');
const settingsPenaltyHr  = document.getElementById('settingsPenaltyHour');
const settingsSaveBtn    = document.getElementById('settingsSaveBtn');
const settingsCancelBtn  = document.getElementById('settingsCancelBtn');
const settingsExportBtn  = document.getElementById('settingsExportBtn');
const settingsImportBtn  = document.getElementById('settingsImportBtn');
const settingsImportIn   = document.getElementById('settingsImportInput');
const settingsResetBtn   = document.getElementById('settingsResetBtn');

function openSettingsModal() {
  // Prefill current values from state
  settingsPenaltyHr.value = (state.penaltyTriggerHour != null) ? state.penaltyTriggerHour : 10;
  settingsModal.classList.add('active');
  setTimeout(() => settingsPenaltyHr.focus(), 100);
}

function closeSettingsModal() {
  settingsModal.classList.remove('active');
}

settingsToggle.addEventListener('click', openSettingsModal);
settingsCancelBtn.addEventListener('click', closeSettingsModal);

// Click outside to close
settingsModal.addEventListener('click', (e) => {
  if (e.target.id === 'settingsModal') closeSettingsModal();
});

/* ---- Save penalty hour ---- */
settingsSaveBtn.addEventListener('click', () => {
  const raw = settingsPenaltyHr.value;
  const hr = parseInt(raw, 10);
  if (isNaN(hr) || hr < 0 || hr > 23) {
    showToast('INVALID HOUR. ENTER 0–23.', 'danger');
    return;
  }
  const prev = state.penaltyTriggerHour;
  state.penaltyTriggerHour = hr;

  // If the user changed the hour, allow the penalty check to re-evaluate today
  // (so moving the trigger later in the day doesn't leave a stale triggered flag)
  if (prev !== hr) {
    state.penaltyTriggeredDate = null;
  }

  saveState();
  logMessage(`PENALTY TRIGGER RECALIBRATED — ${String(hr).padStart(2, '0')}:00`, 'accent');
  checkPenaltyOnLoad();
  render();
  closeSettingsModal();
  showToast(`PENALTY HOUR SET TO ${String(hr).padStart(2, '0')}:00.`, 'accent');
});

/* ---- Export JSON ---- */
settingsExportBtn.addEventListener('click', () => {
  try {
    const payload = {
      _meta: {
        app: 'THE SYSTEM',
        phase: 5,
        exportedAt: new Date().toISOString(),
        storageKey: STORAGE_KEY
      },
      state: state
    };
    const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const today = todayISO();
    const a = document.createElement('a');
    a.href = url;
    a.download = `the-system-backup-${today}.json`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    setTimeout(() => URL.revokeObjectURL(url), 1000);

    logMessage('SYSTEM STATE EXPORTED', 'accent');
    showToast('EXPORT COMPLETE. BACKUP DOWNLOADED.', 'accent');
  } catch (e) {
    console.error('Export failed', e);
    showToast('EXPORT FAILED.', 'danger');
  }
});

/* ---- Import JSON ---- */
settingsImportBtn.addEventListener('click', () => {
  settingsImportIn.value = ''; // reset so re-selecting same file fires change
  settingsImportIn.click();
});

settingsImportIn.addEventListener('change', (e) => {
  const file = e.target.files && e.target.files[0];
  if (!file) return;

  const reader = new FileReader();
  reader.onload = (ev) => {
    let parsed;
    try {
      parsed = JSON.parse(ev.target.result);
    } catch (err) {
      showToast('INVALID JSON. IMPORT ABORTED.', 'danger');
      return;
    }

    // Accept either the wrapped export { _meta, state } or a raw state object
    let incoming = null;
    if (parsed && typeof parsed === 'object') {
      if (parsed.state && typeof parsed.state === 'object') {
        incoming = parsed.state;
      } else if (Array.isArray(parsed.quests)) {
        incoming = parsed;
      }
    }

    if (!incoming || !Array.isArray(incoming.quests)) {
      showToast('FILE DOES NOT LOOK LIKE A SYSTEM BACKUP.', 'danger');
      return;
    }

    const questCount = incoming.quests.length;
    const xp = incoming.totalXp != null ? incoming.totalXp : 0;
    const ok = confirm(
      `Import this backup?\n\n` +
      `• Quests: ${questCount}\n` +
      `• Total EXP: ${xp}\n\n` +
      `Your current progress will be REPLACED. This cannot be undone.`
    );
    if (!ok) {
      showToast('IMPORT CANCELLED.', 'normal');
      return;
    }

    try {
      // Merge over defaults so missing fields from older exports get sane values
      // via the migration block on next load.
      localStorage.setItem(STORAGE_KEY, JSON.stringify(incoming));
      logMessage('SYSTEM STATE IMPORTED — RELOADING', 'accent');
      showToast('IMPORT COMPLETE. RELOADING.', 'accent');
      setTimeout(() => { location.reload(); }, 700);
    } catch (err) {
      console.error('Import save failed', err);
      showToast('IMPORT FAILED DURING SAVE.', 'danger');
    }
  };
  reader.onerror = () => {
    showToast('FAILED TO READ FILE.', 'danger');
  };
  reader.readAsText(file);
});

/* ---- Reset everything ---- */
settingsResetBtn.addEventListener('click', () => {
  const ok1 = confirm(
    'RESET EVERYTHING?\n\n' +
    'This will permanently wipe ALL System data:\n' +
    '• All quests and completions\n' +
    '• EXP, rank, stats, streaks\n' +
    '• Shadows, achievements, titles\n' +
    '• Body Forge data\n' +
    '• Commitments and RCA history\n\n' +
    'This cannot be undone.'
  );
  if (!ok1) return;

  const ok2 = confirm(
    'FINAL CONFIRMATION.\n\n' +
    'Type-less confirm: are you absolutely sure you want to delete all System data?'
  );
  if (!ok2) {
    showToast('RESET CANCELLED.', 'normal');
    return;
  }

  try {
    localStorage.removeItem(STORAGE_KEY);
    // Clear any lingering Phase 1 keys if present, for safety
    try { localStorage.removeItem('the_system_v1'); } catch (_) {}
    setTimeout(() => { location.reload(); }, 400);
  } catch (err) {
    console.error('Reset failed', err);
    showToast('RESET FAILED.', 'danger');
  }
});

/* ============ FEED PANEL TOGGLE ============ */
const feedPanel = document.getElementById('feedPanel');
const feedToggle = document.getElementById('feedToggle');
const feedClose = document.getElementById('feedClose');

feedToggle.addEventListener('click', () => {
  feedPanel.classList.toggle('open');
});

feedClose.addEventListener('click', () => {
  feedPanel.classList.remove('open');
});

// Click outside to close feed panel
document.addEventListener('click', (e) => {
  if (!feedPanel.classList.contains('open')) return;
  if (!feedPanel.contains(e.target) && !feedToggle.contains(e.target)) {
    feedPanel.classList.remove('open');
  }
});

/* ============ INIT ============ */
loadState();

// Ensure rank index matches XP (handles storage from Phase 2 with old thresholds)
state.currentRankIdx = calculateRank(state.totalXp);

// Migrate Phase 2 users: tag existing untagged quests as 'user'
state.quests.forEach(q => {
  if (!q.source) q.source = 'user';
  if (!q.missionType) q.missionType = 'user';
});

// Phase 3: ensure state fields exist for users upgrading from Phase 2/2.5
if (!state.stats)         state.stats = { INT: 0, STR: 0, VIT: 0, AGI: 0, SEN: 0 };
if (state.streak === undefined)         state.streak = 0;
if (state.penaltyTriggerHour === undefined) state.penaltyTriggerHour = 10;
if (!state.messageFeed)   state.messageFeed = [];
if (!state.overdueLoggedIds) state.overdueLoggedIds = [];

// Phase 4: ensure state fields exist for users upgrading from Phase 3
if (!state.unlockedShadows)      state.unlockedShadows = [];
if (!state.unlockedAchievements) state.unlockedAchievements = [];
if (!state.earnedTitles)         state.earnedTitles = [];
if (state.activeTitle === undefined) state.activeTitle = null;
if (!state.activeTab)            state.activeTab = 'quests';
if (state.maxStreakEver === undefined)      state.maxStreakEver = state.streak || 0;
if (state.totalQuestsCompleted === undefined) {
  // Retroactively count lifetime completions from existing quest history
  state.totalQuestsCompleted = state.quests.filter(q => q.completed).length;
}
if (!state.questsCompletedByCategory) {
  state.questsCompletedByCategory = { scholar: 0, research: 0, iron: 0, dungeon: 0, recovery: 0 };
  // Retroactively populate
  for (const q of state.quests) {
    if (q.completed && q.category) {
      state.questsCompletedByCategory[q.category] = (state.questsCompletedByCategory[q.category] || 0) + 1;
    }
  }
}
if (state.dailyQuoteDate === undefined) state.dailyQuoteDate = null;
if (state.dailyQuoteIndex === undefined) state.dailyQuoteIndex = 0;

// Phase 4.5: ensure bodyStats exists
ensureBodyStats();
if (!state.bodyBossesUnlocked) state.bodyBossesUnlocked = [];

// Phase 5: ensure commitment/session fields exist
if (!state.commitments) state.commitments = [];
if (!state.rcaSessions) state.rcaSessions = [];

// Run overdue commitment check on load
checkOverdueCommitments();

// Reset overdueLoggedIds if it's a new day
if (state.lastResetDate !== todayISO()) {
  state.overdueLoggedIds = [];
}

handleDailyReset();
checkStreakDecay();
checkAndLogOverdue();
checkPenaltyOnLoad();

// Phase 4: retroactive unlock check on load (don't animate, just populate)
// This catches users who earned unlocks pre-Phase 4 or through Phase 4 features quietly
const _previousUnlockQueue = unlockQueue;
unlockQueue = [];
const _previousShow = unlockShowing;
checkAndUnlockProgress();
// Suppress cinematic on load — just silently acknowledge any retroactive unlocks
unlockQueue = [];

// Restore active tab from saved state
if (state.activeTab && state.activeTab !== 'quests') {
  switchTab(state.activeTab);
}

render();

/* ============ PERIODIC CHECKS ============ */
// Every 60s: refresh quest board to update overdue visuals, re-check overdue logging
setInterval(() => {
  checkAndLogOverdue();
  checkOverdueCommitments();
  renderQuests();
  renderFeed();
  renderEmergencyTab();
}, 60000);

// Every 5 min: re-check penalty (in case user stays open past trigger hour without completing anything)
setInterval(() => {
  checkPenaltyOnLoad();
  render();
}, 5 * 60 * 1000);

</script>

