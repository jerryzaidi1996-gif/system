};

function loadState() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (raw) {
      const parsed = JSON.parse(raw);
      state = { ...state, ...parsed };
    }
  } catch (e) {
    console.warn('Failed to load state', e);
  }
}

function saveState() {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  } catch (e) {
    console.warn('Failed to save state', e);
  }
}

/* ============ DAILY RESET ============ */
function todayISO() {
  const d = new Date();
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
}

function getMondayOfWeek(date = new Date()) {
  const d = new Date(date);
  const day = d.getDay();
  const diff = (day === 0 ? -6 : 1 - day); // treat Monday as week start
  d.setDate(d.getDate() + diff);
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
}

function getFirstOfMonth(date = new Date()) {
  return `${date.getFullYear()}-${String(date.getMonth()+1).padStart(2,'0')}-01`;
}

function assignQuestId(q) {
  return {
    id: 'q_' + Date.now() + '_' + Math.random().toString(36).slice(2, 8),
    name: q.text,
    category: q.category,
    difficulty: q.d,
    dueTime: null,
    completed: false,
    completedAt: null,
    createdAt: new Date().toISOString(),
    source: q.source || 'system'      // 'system' or 'user'
  };
}

function generateAndAssignDailyMissions() {
  const rankIdx = state.currentRankIdx;

  // 1. Generate 3 Daily Directives (mandatory)
  const directives = generateDailyDirectives(rankIdx);
  directives.forEach(d => {
    const q = assignQuestId({ ...d, source: 'directive' });
    q.missionType = 'directive';
    state.quests.push(q);
  });

  // 2. Generate 5 Side Quests (optional)
  const usedTexts = directives.map(d => d.text);
  const sideQuests = generateSideQuests(rankIdx, usedTexts);
  sideQuests.forEach(s => {
    const q = assignQuestId({ ...s, source: 'side' });
    q.missionType = 'side';
    state.quests.push(q);
  });
}

function assignWeeklyMissionIfNeeded() {
  const currentWeekStart = getMondayOfWeek();
  if (state.weeklyWeekStart !== currentWeekStart) {
    const tpl = generateWeeklyMission(state.currentRankIdx);
    state.weeklyMission = {
      ...tpl,
      assignedDate: todayISO(),
      weekStart: currentWeekStart,
      completed: false
    };
    state.weeklyWeekStart = currentWeekStart;
  }
}

function assignMonthlyArcIfNeeded() {
  const currentMonthStart = getFirstOfMonth();
  if (state.monthlyMonthStart !== currentMonthStart) {
    const tpl = generateMonthlyArc(state.currentRankIdx);
    state.monthlyArc = {
      ...tpl,
      assignedDate: todayISO(),
      monthStart: currentMonthStart,
      completed: false
    };
    state.monthlyMonthStart = currentMonthStart;
  }
}

function assignLongTermDungeonIfNeeded() {
  if (!state.longTermDungeon || state.longTermDungeon.completed) {
    const tpl = generateLongTermDungeon(state.currentRankIdx);
    state.longTermDungeon = {
      ...tpl,
      assignedDate: todayISO(),
      completed: false
    };
  }
}

function handleDailyReset() {
  const today = todayISO();

  if (state.directivesGeneratedDate !== today) {
    // Remove yesterday's incomplete system-generated directives + side quests
    // Keep user-created quests, keep today's completed ones
    state.quests = state.quests.filter(q => {
      // Always keep user-created
      if (q.source === 'user' || !q.source) {
        // But still clear user-created completed quests from previous days
        if (q.completed && q.completedAt) {
          const completedDay = q.completedAt.substring(0, 10);
          return completedDay === today;
        }
        return true;
      }
      // System quests (directive/side): drop unless completed today
      if (q.completed && q.completedAt) {
        const completedDay = q.completedAt.substring(0, 10);
        return completedDay === today;
      }
      return false; // drop incomplete system quests from prior days
    });

    generateAndAssignDailyMissions();
    state.directivesGeneratedDate = today;
  }

  assignWeeklyMissionIfNeeded();
  assignMonthlyArcIfNeeded();
  assignLongTermDungeonIfNeeded();

  state.lastResetDate = today;
  saveState();
}

/* ============ RANK CALCULATION ============ */
function calculateRank(xp) {
  let idx = 0;
  for (let i = 0; i < RANKS.length; i++) {
    if (xp >= RANKS[i].threshold) idx = i;
  }
  return idx;
}

function nextRankThreshold(currentIdx) {
  if (currentIdx >= RANKS.length - 1) return RANKS[currentIdx].threshold;
  return RANKS[currentIdx + 1].threshold;
}

function xpProgressInTier(xp, rankIdx) {
  const currTier = RANKS[rankIdx].threshold;
  const nextTier = nextRankThreshold(rankIdx);
  if (nextTier === currTier) return { current: xp - currTier, max: 0, pct: 100 };
  const inTier = xp - currTier;
  const tierSize = nextTier - currTier;
  return { current: inTier, max: tierSize, pct: (inTier / tierSize) * 100 };
}

/* ============ RENDER ============ */
function renderHeader() {
  const rank = RANKS[state.currentRankIdx];
  document.getElementById('rankBadge').textContent = rank.name;

  const titleEl = document.getElementById('hunterTitle');
  if (state.activeTitle) {
    titleEl.textContent = state.activeTitle;
    const parent = titleEl.closest('.hunter-title');
    if (parent) parent.classList.add('equipped');
  } else {
    titleEl.textContent = rank.title;
    const parent = titleEl.closest('.hunter-title');
    if (parent) parent.classList.remove('equipped');
  }

  const prog = xpProgressInTier(state.totalXp, state.currentRankIdx);
  document.getElementById('xpFill').style.width = prog.pct + '%';
  document.getElementById('xpText').innerHTML =
    prog.max === 0
      ? `${state.totalXp.toLocaleString()}&nbsp;EXP`
      : `${prog.current.toLocaleString()}&nbsp;/&nbsp;${prog.max.toLocaleString()}`;
}

function renderQuests() {
  // Clear all quest-list containers
  document.querySelectorAll('.quest-list').forEach(el => el.innerHTML = '');

  // Group quests by category
  const grouped = {};
  for (const cat of Object.keys(CATEGORIES)) grouped[cat] = [];

  // Sort: active first, then overdue, then completed
  const sorted = [...state.quests].sort((a, b) => {
    if (a.completed && !b.completed) return 1;
    if (!a.completed && b.completed) return -1;
    return (a.createdAt || '').localeCompare(b.createdAt || '');
  });

  for (const q of sorted) {
    if (grouped[q.category]) grouped[q.category].push(q);
  }

  // Render each category
  for (const [cat, quests] of Object.entries(grouped)) {
    const container = document.querySelector(`.quest-list[data-category="${cat}"]`);
    if (!container) continue;

    if (quests.length === 0) {
      container.innerHTML = `<div class="quest-empty">『 No active quests 』</div>`;
      continue;
    }

    for (const q of quests) {
      container.appendChild(createQuestRow(q));
    }
  }
}

function createQuestRow(q) {
  const row = document.createElement('div');
  row.className = 'quest-row';
  if (q.completed) row.classList.add('completed');
  if (isOverdue(q)) row.classList.add('overdue');
  if (q.missionType === 'directive') row.classList.add('directive');
  if (q.missionType === 'penalty') row.classList.add('penalty');
  row.dataset.id = q.id;

  const info = document.createElement('div');
  info.className = 'quest-info';

  // Mission type badge
  if (q.missionType === 'penalty') {
    const badge = document.createElement('span');
    badge.className = 'mission-badge penalty';
    badge.textContent = 'PENALTY';
    info.appendChild(badge);
  } else if (q.missionType === 'directive') {
    const badge = document.createElement('span');
    badge.className = 'mission-badge directive';
    badge.textContent = 'DIRECTIVE';
    info.appendChild(badge);
  } else if (q.missionType === 'side') {
    const badge = document.createElement('span');
    badge.className = 'mission-badge side';
    badge.textContent = 'SIDE';
    info.appendChild(badge);
  }

  const name = document.createElement('span');
  name.className = 'quest-name';
  name.textContent = q.name;
  info.appendChild(name);

  const diff = document.createElement('span');
  diff.className = `difficulty ${q.difficulty}`;
  diff.textContent = q.difficulty.toUpperCase();
  info.appendChild(diff);

  if (q.dueTime) {
    const dueEl = document.createElement('span');
    dueEl.className = 'due-time';
    dueEl.textContent = q.dueTime;
    info.appendChild(dueEl);
  }

  row.appendChild(info);

  const actions = document.createElement('div');
  actions.className = 'quest-actions';

  const completeBtn = document.createElement('button');
  completeBtn.className = 'complete-btn ' + (q.completed ? 'done' : 'active');
  completeBtn.textContent = q.completed ? '✓ DONE' : 'COMPLETE';
  if (!q.completed) {
    completeBtn.addEventListener('click', () => completeQuest(q.id));
  }

  actions.appendChild(completeBtn);

  // Phase 5: Add "STUCK" button that launches Emergency Protocol pre-loaded with this quest
  if (!q.completed) {
    const stuckBtn = document.createElement('button');
    stuckBtn.className = 'stuck-btn';
    stuckBtn.innerHTML = '⚠';
    stuckBtn.title = 'Launch Emergency Protocol';
    stuckBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      launchEmergencyProtocol(q);
    });
    actions.appendChild(stuckBtn);
  }

  // Only allow delete on user-created quests — System-assigned missions cannot be refused
  if (q.source === 'user') {
    const deleteBtn = document.createElement('button');
    deleteBtn.className = 'delete-btn';
    deleteBtn.innerHTML = '×';
    deleteBtn.title = 'Delete quest';
    deleteBtn.addEventListener('click', () => deleteQuest(q.id));
    actions.appendChild(deleteBtn);
  }

  row.appendChild(actions);

  return row;
}

function isOverdue(q) {
  if (q.completed || !q.dueTime) return false;
  const now = new Date();
  const [hh, mm] = q.dueTime.split(':').map(Number);
  const due = new Date();
  due.setHours(hh, mm, 0, 0);
  return now > due;
}

