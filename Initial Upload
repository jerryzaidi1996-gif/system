  const dateStr = target.toLocaleDateString([], { weekday: 'short', month: 'short', day: 'numeric' });

  const driverLabel = {
    perfectionism: 'Perfectionism',
    overwhelm: 'Overwhelm',
    ambiguity: 'Ambiguity',
    aversion: 'Aversion',
    low_stakes: 'Low Stakes'
  }[c.driver] || c.driver;

  el.innerHTML = `
    <div><span class="label">Target:</span>${c.questName}</div>
    <div><span class="label">Threat:</span>${driverLabel}</div>
    <div><span class="label">Checkpoint:</span>${timeStr} &middot; ${dateStr}</div>
  `;
}

