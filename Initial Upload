function openBodySetup() {
  ensureBodyStats();
  const modal = document.getElementById('bodySetupModal');
  const wEl = document.getElementById('setupStartWeight');
  const gEl = document.getElementById('setupGoalWeight');
  const pEl = document.getElementById('setupPace');
  wEl.value = state.bodyStats.startWeight || '';
  gEl.value = state.bodyStats.goalWeight || '';
  pEl.value = state.bodyStats.goalPaceLbPerWeek || 2;
  modal.classList.add('active');
  setTimeout(() => wEl.focus(), 100);
}

document.getElementById('cancelBodySetupBtn').addEventListener('click', () => {
  document.getElementById('bodySetupModal').classList.remove('active');
});

document.getElementById('confirmBodySetupBtn').addEventListener('click', () => {
  const w = parseFloat(document.getElementById('setupStartWeight').value);
  const g = parseFloat(document.getElementById('setupGoalWeight').value);
  const p = parseFloat(document.getElementById('setupPace').value);

  if (isNaN(w) || w <= 0 || isNaN(g) || g <= 0 || isNaN(p) || p <= 0) {
    showToast('INVALID VALUES. RETRY.', 'danger');
    return;
  }

  ensureBodyStats();
  const today = todayISO();

  // If first configuration, seed starting values and first weight entry
  if (!state.bodyStats.configured) {
    state.bodyStats.startWeight = w;
    state.bodyStats.startDate = today;
    if (state.bodyStats.weightHistory.length === 0) {
      state.bodyStats.weightHistory.push({ date: today, weight: w });
    }
    if (!state.bodyStats.dailyCheckIns[today]) state.bodyStats.dailyCheckIns[today] = {};
    state.bodyStats.dailyCheckIns[today].weight = w;
  }
  state.bodyStats.goalWeight = g;
  state.bodyStats.goalPaceLbPerWeek = p;
  state.bodyStats.configured = true;

  logMessage(`BODY FORGE INITIALIZED — START: ${w} LB · GOAL: ${g} LB · PACE: ${p} LB/WK`, 'rank');
  checkWeightMilestones();
  saveState();
  render();

  document.getElementById('bodySetupModal').classList.remove('active');
  showToast('BODY FORGE INITIALIZED. THE WORK BEGINS.', 'accent');
});

function openMeasurementsModal() {
  const modal = document.getElementById('measurementsModal');
  const today = todayISO();
  // Pre-fill with most recent measurement
  const recent = (state.bodyStats.measurements || []).slice(-1)[0];
  document.getElementById('measWaist').value = recent?.waist || '';
  document.getElementById('measChest').value = recent?.chest || '';
  document.getElementById('measHips').value = recent?.hips || '';
  modal.classList.add('active');
  setTimeout(() => document.getElementById('measWaist').focus(), 100);
}

document.getElementById('cancelMeasBtn').addEventListener('click', () => {
  document.getElementById('measurementsModal').classList.remove('active');
});

document.getElementById('confirmMeasBtn').addEventListener('click', () => {
  const waist = parseFloat(document.getElementById('measWaist').value);
  const chest = parseFloat(document.getElementById('measChest').value);
  const hips = parseFloat(document.getElementById('measHips').value);

  const data = {};
  if (!isNaN(waist) && waist > 0) data.waist = waist;
  if (!isNaN(chest) && chest > 0) data.chest = chest;
  if (!isNaN(hips) && hips > 0) data.hips = hips;

  if (Object.keys(data).length === 0) {
    showToast('NO VALUES ENTERED.', 'danger');
    return;
  }

  logMeasurements(data);

  // Award EXP for the measurement check-in
  state.totalXp += 25;
  state.stats.VIT = (state.stats.VIT || 0) + 2;
  logMessage(`MEASUREMENTS LOGGED — +25 EXP`, 'xp');

