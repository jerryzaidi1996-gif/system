/* ============ UNLOCK CINEMATIC (SHADOW/ACHIEVEMENT) ============ */
.unlock-overlay {
position: fixed;
inset: 0;
z-index: 998;
background: radial-gradient(ellipse at center, rgba(2, 3, 9, 0.94) 0%, rgba(2, 3, 9, 1) 80%);
display: flex;
align-items: center;
justify-content: center;
padding: 20px;
opacity: 0;
visibility: hidden;
transition: opacity 0.4s, visibility 0.4s;
}

.unlock-overlay.active {
opacity: 1;
visibility: visible;
}

.unlock-overlay::before {
content: ‘’;
position: absolute;
inset: 0;
background-image:
radial-gradient(ellipse at center, rgba(92, 230, 240, 0.1) 0%, transparent 60%),
linear-gradient(90deg, transparent 49.7%, rgba(92, 230, 240, 0.05) 50%, transparent 50.3%),
linear-gradient(0deg, transparent 49.7%, rgba(92, 230, 240, 0.04) 50%, transparent 50.3%);
background-size: 100% 100%, 40px 40px, 40px 40px;
animation: grid-drift 30s linear infinite;
pointer-events: none;
}

.unlock-window {
position: relative;
width: 100%;
max-width: 480px;
background: var(–bg-panel);
border: 2px solid var(–accent-cyan);
outline: 1px solid var(–accent-cyan);
outline-offset: 5px;
box-shadow: 0 0 40px rgba(92, 230, 240, 0.7), 0 0 120px rgba(92, 230, 240, 0.3);
transform: scale(0.85);
transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}

.unlock-overlay.active .unlock-window {
transform: scale(1);
}

.unlock-window .corner {
position: absolute;
width: 16px;
height: 16px;
border-color: var(–accent-cyan-bright);
pointer-events: none;
}
.unlock-window .corner.tl { top: -3px; left: -3px; border-top: 3px solid; border-left: 3px solid; }
.unlock-window .corner.tr { top: -3px; right: -3px; border-top: 3px solid; border-right: 3px solid; }
.unlock-window .corner.bl { bottom: -3px; left: -3px; border-bottom: 3px solid; border-left: 3px solid; }
.unlock-window .corner.br { bottom: -3px; right: -3px; border-bottom: 3px solid; border-right: 3px solid; }

.unlock-header {
display: flex;
align-items: center;
justify-content: center;
gap: 10px;
padding: 10px 20px;
background: linear-gradient(180deg, rgba(92, 230, 240, 0.28), rgba(92, 230, 240, 0.08));
border-bottom: 2px solid var(–accent-cyan);
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: 11px;
letter-spacing: 0.5em;
color: var(–accent-cyan-bright);
text-shadow: 0 0 10px var(–accent-cyan);
text-transform: uppercase;
}

.unlock-body {
padding: 28px 28px 28px;
text-align: center;
}

.unlock-silhouette {
position: relative;
height: 200px;
margin-bottom: 18px;
display: flex;
align-items: flex-end;
justify-content: center;
background: radial-gradient(ellipse at center, rgba(92, 230, 240, 0.15) 0%, transparent 70%);
}

.unlock-silhouette-figure {
width: 50%;
height: 85%;
background: #000;
clip-path: polygon(
48% 3%, 52% 3%,
56% 8%, 58% 14%, 56% 22%,
64% 26%,
70% 32%, 76% 42%, 80% 56%, 76% 70%, 72% 82%, 68% 95%,
58% 95%, 56% 70%,
44% 70%, 42% 95%,
32% 95%, 28% 82%, 24% 70%, 20% 56%, 24% 42%, 30% 32%,
36% 26%,
44% 22%, 42% 14%, 44% 8%
);
filter: drop-shadow(0 0 18px rgba(92, 230, 240, 0.8));
animation: unlock-rise 1.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.unlock-silhouette-eyes {
position: absolute;
top: 25%;
left: 50%;
transform: translateX(-50%);
width: 24px;
height: 4px;
display: flex;
gap: 8px;
}

.unlock-silhouette-eyes::before,
.unlock-silhouette-eyes::after {
content: ‘’;
flex: 1;
height: 100%;
background: var(–accent-cyan-bright);
border-radius: 50%;
box-shadow: 0 0 10px var(–accent-cyan), 0 0 20px var(–accent-cyan);
animation: unlock-eye-appear 1.5s ease 0.8s both;
}

@keyframes unlock-rise {
from { transform: translateY(40px); opacity: 0; }
to   { transform: translateY(0); opacity: 1; }
}

@keyframes unlock-eye-appear {
from { opacity: 0; transform: scale(0.3); }
to   { opacity: 1; transform: scale(1); }
}

.unlock-name {
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: 24px;
letter-spacing: 0.45em;
color: var(–gold-soft);
text-shadow: 0 0 10px var(–gold);
margin-bottom: 6px;
}

.unlock-class {
font-family: ‘Orbitron’, sans-serif;
font-size: 11px;
letter-spacing: 0.3em;
color: var(–accent-cyan-bright);
text-transform: uppercase;
margin-bottom: 18px;
}

.unlock-flavor {
font-family: ‘JetBrains Mono’, monospace;
font-size: 12px;
color: var(–text-primary);
font-style: italic;
line-height: 1.7;
letter-spacing: 0.06em;
margin-bottom: 26px;
}

.unlock-dismiss {
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: 11px;
letter-spacing: 0.5em;
padding: 12px 36px;
border: 1px solid var(–accent-cyan);
background: rgba(92, 230, 240, 0.1);
color: var(–accent-cyan-bright);
text-shadow: 0 0 8px var(–accent-cyan);
cursor: pointer;
transition: all 0.2s;
text-transform: uppercase;
}

.unlock-dismiss:hover:not(:disabled) {
background: rgba(92, 230, 240, 0.22);
box-shadow: 0 0 20px rgba(92, 230, 240, 0.5);
}

.unlock-dismiss:disabled {
opacity: 0.4;
cursor: not-allowed;
}

/* Achievement variant of unlock modal */
.unlock-overlay[data-type=“achievement”] .unlock-window {
border-color: var(–gold);
outline-color: var(–gold);
box-shadow: 0 0 40px rgba(245, 196, 81, 0.7), 0 0 120px rgba(245, 196, 81, 0.3);
}

.unlock-overlay[data-type=“achievement”] .unlock-window .corner { border-color: var(–gold-soft); }

.unlock-overlay[data-type=“achievement”] .unlock-header {
background: linear-gradient(180deg, rgba(245, 196, 81, 0.28), rgba(245, 196, 81, 0.08));
border-bottom-color: var(–gold);
color: var(–gold-soft);
text-shadow: 0 0 10px var(–gold);
}

.unlock-overlay[data-type=“achievement”] .unlock-silhouette-figure {
display: none;
}

.unlock-overlay[data-type=“achievement”] .unlock-silhouette-eyes { display: none; }

.unlock-overlay[data-type=“achievement”] .unlock-silhouette {
display: flex;
align-items: center;
}

.unlock-overlay[data-type=“achievement”] .unlock-silhouette::before {
content: ‘✦’;
font-family: ‘Orbitron’, sans-serif;
font-size: 100px;
color: var(–gold-soft);
text-shadow: 0 0 30px var(–gold), 0 0 60px var(–gold);
animation: unlock-rise 1.2s cubic-bezier(0.16, 1, 0.3, 1), ach-sparkle 3s ease-in-out infinite;
margin: 0 auto;
}

@keyframes ach-sparkle {
0%, 100% { transform: scale(1) rotate(0deg); }
50%      { transform: scale(1.1) rotate(10deg); }
}

.unlock-overlay[data-type=“achievement”] .unlock-dismiss {
border-color: var(–gold);
color: var(–gold-soft);
text-shadow: 0 0 8px var(–gold);
background: rgba(245, 196, 81, 0.1);
}

.unlock-overlay[data-type=“achievement”] .unlock-dismiss:hover:not(:disabled) {
background: rgba(245, 196, 81, 0.22);
box-shadow: 0 0 20px rgba(245, 196, 81, 0.5);
}

/* Title clickable display in header */
.hunter-title {
cursor: pointer;
transition: color 0.2s, text-shadow 0.2s;
}

.hunter-title:hover {
color: var(–accent-cyan-bright);
text-shadow: 0 0 6px var(–accent-cyan);
}

.hunter-title.equipped {
color: var(–gold-soft);
text-shadow: 0 0 6px var(–gold);
}

